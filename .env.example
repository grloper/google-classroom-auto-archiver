GOOGLE_EMAIL=user@gmail.com
# Intentionally unused by the app. Google login should be completed interactively once.
GOOGLE_PASSWORD=

HEADLESS=true
DOWNLOAD_PATH=./output
DB_PATH=./database/classroom.db
LOG_LEVEL=info

MAX_CONCURRENT_DOWNLOADS=5
REQUEST_DELAY_MS=250
MAX_RETRIES=4

ENABLE_API_MODE=true
ENABLE_UI_FALLBACK=true
COURSE_STATES=ACTIVE,ARCHIVED

# Create an OAuth desktop client in Google Cloud and download it here.
# The file can use Google's standard {"installed": {...}} format.
GOOGLE_APPLICATION_CREDENTIALS=./credentials/oauth-client.json
GOOGLE_OAUTH_TOKEN_PATH=./sessions/google-oauth-token.json
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost

API_PORT=4317
API_HOST=127.0.0.1
